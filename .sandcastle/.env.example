# Ollama Cloud API key — create one at https://ollama.com/settings/keys
OLLAMA_API_KEY=

# pi model id — use provider/model as shown by `pi --list-models` in the sandbox
OLLAMA_CLOUD_MODEL=ollama-cloud/kimi-k2.6

